root = true

[*.{kt,kts,java,xml,gradle,md,txt,properties,pro}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{png,jpg,jpeg,gif,webp,apk,keystore,jks}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
